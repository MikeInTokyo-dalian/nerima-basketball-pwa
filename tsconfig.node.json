{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node", "electron-vite/node"]
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/mobile-server/**/*.ts",
    "src/shared/**/*.ts",
    "api/**/*.ts",
    "vite.mobile*.ts",
    "tests/main/**/*.ts"
  ]
}
